{
  "$schema": "https://biomejs.dev/schemas/2.4.12/schema.json",
  "files": {
    "ignoreUnknown": true,
    "maxSize": 2097152,
    "includes": [
      "**",
      "!**/.nuxt",
      "!**/.output",
      "!**/coverage",
      "!**/playwright-report",
      "!**/test-results",
      "!**/node_modules",
      "!**/data/source-snapshots",
      "!**/data/vocabulary-candidates.json",
      "!**/data/vocabulary.json",
      "!**/data/vocabulary-metadata.json",
      "!**/data/vocabulary-level-1.json",
      "!**/data/vocabulary-level-2.json",
      "!**/data/vocabulary-level-3.json",
      "!**/public/wordlists"
    ]
  },
  "formatter": {
    "enabled": true,
    "indentStyle": "space",
    "indentWidth": 2,
    "lineWidth": 100
  },
  "assist": { "actions": { "source": { "organizeImports": "on" } } },
  "linter": {
    "enabled": true,
    "rules": {
      "recommended": true
    }
  },
  "javascript": {
    "formatter": {
      "quoteStyle": "single",
      "trailingCommas": "es5"
    }
  },
  "json": {
    "formatter": {
      "trailingCommas": "none"
    }
  },
  "overrides": [
    {
      "includes": ["**/*.vue"],
      "linter": {
        "rules": {
          "correctness": {
            "noUnusedVariables": "off"
          }
        }
      }
    }
  ]
}
